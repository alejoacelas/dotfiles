#!/usr/bin/env bash
# Block commits that introduce an obvious credential.
# Override a false positive with:  git commit --no-verify
pat='gh[opsu]_[A-Za-z0-9]{20,}|sk-[A-Za-z0-9]{20,}|AKIA[0-9A-Z]{16}|xox[baprs]-[A-Za-z0-9-]{8,}|BEGIN [A-Z ]*PRIVATE KEY|(API_KEY|SECRET|TOKEN|PASSWORD)=[A-Za-z0-9_./-]{16,}'

added=$(git diff --cached -U0 --no-color | grep -E '^\+[^+]' || true)
if printf '%s' "$added" | grep -qEi "$pat"; then
  echo "pre-commit: a staged line looks like a credential — commit blocked:" >&2
  printf '%s\n' "$added" | grep -nEi "$pat" | head -5 >&2
  echo "Move it to settings.local.json / env, or override with: git commit --no-verify" >&2
  exit 1
fi
exit 0
