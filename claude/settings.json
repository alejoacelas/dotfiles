{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 36500,
  "permissions": {
    "allow": [
      "Bash(brew install:*)",
      "Bash(brew update:*)",
      "Bash(brew upgrade:*)",
      "Bash(brew info:*)",
      "Bash(brew search:*)",
      "Bash(brew list:*)",
      "Bash(brew link:*)",
      "Bash(brew unlink:*)",
      "Bash(brew tap:*)",
      "Bash(brew --prefix:*)",
      "Bash(uv:*)",
      "Bash(uvx:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(corepack:*)",
      "Bash(cargo:*)",
      "Bash(rustup:*)",
      "Bash(rustc:*)",
      "Bash(python3:*)",
      "Bash(pip3:*)",
      "Bash(pip:*)",
      "Bash(gh:*)"
    ]
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$CLAUDE_PROJECT_DIR\" = \"$HOME/people\" ]; then python3 \"$HOME/best/ai/dotfiles/claude/hooks/sync_gate.py\"; fi"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/best/ai/dotfiles/claude/hooks/guard-judgment.py\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark"
}
